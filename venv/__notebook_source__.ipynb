# ============================================================
# Panel 1: Distribution Shift (KDE)
# Non-Potable → Potable per feature | White Theme
# ============================================================
from matplotlib.animation import FuncAnimation, PillowWriter
from IPython.display import Image, display
from scipy.stats import gaussian_kde
import numpy as np

features    = list(df.columns[:-1])
COLOR_0     = '#FF0087'   # Non-Potable
COLOR_1     = '#00F7FF'   # Potable
COLOR_SHIFT = '#e05c2a'
STEPS       = 50
HOLD        = 10

kde_data = []
for feat in features:
    v0 = df[df['Potability'] == 0][feat].dropna().values
    v1 = df[df['Potability'] == 1][feat].dropna().values

    x_min  = min(v0.min(), v1.min())
    x_max  = max(v0.max(), v1.max())
    x_grid = np.linspace(x_min, x_max, 300)
    k0     = gaussian_kde(v0, bw_method=0.3)(x_grid)
    k1     = gaussian_kde(v1, bw_method=0.3)(x_grid)

    kde_data.append({
        'feature': feat,
        'x_grid':  x_grid,
        'k0': k0, 'k1': k1,
        'y_max':   max(k0.max(), k1.max()) * 1.35,
        'mean_0':  v0.mean(), 'mean_1': v1.mean(),
        'std_0':   v0.std(),  'std_1':  v1.std(),
        'kurt_0':  float(pd.Series(v0).kurt()),
        'kurt_1':  float(pd.Series(v1).kurt()),
    })

frame_list = []
for fi in range(len(features)):
    for s in range(STEPS):
        frame_list.append((fi, s / (STEPS - 1)))
    for _ in range(HOLD):
        frame_list.append((fi, 1.0))

def ease(t):
    return t * t * (3 - 2 * t)

def lerp_color(c0, c1, t):
    r0,g0,b0 = int(c0[1:3],16)/255, int(c0[3:5],16)/255, int(c0[5:7],16)/255
    r1,g1,b1 = int(c1[1:3],16)/255, int(c1[3:5],16)/255, int(c1[5:7],16)/255
    return (r0+t*(r1-r0), g0+t*(g1-g0), b0+t*(b1-b0))

fig, ax = plt.subplots(figsize=(13, 6))
fig.patch.set_facecolor('white')

def style_ax(ax):
    ax.set_facecolor('white')
    ax.tick_params(colors='#333')
    ax.grid(True, alpha=0.2, linestyle='--', color='#aaa', axis='y')
    for sp in ax.spines.values():
        sp.set_edgecolor('#ddd')

def animate(frame_idx):
    ax.cla()
    style_ax(ax)

    fi, t  = frame_list[frame_idx]
    et     = ease(t)
    d      = kde_data[fi]
    x      = d['x_grid']
    col    = lerp_color(COLOR_0, COLOR_1, et)

    # Ghost reference fills
    ax.fill_between(x, d['k0'], alpha=0.08, color=COLOR_0)
    ax.fill_between(x, d['k1'], alpha=0.08, color=COLOR_1)
    ax.plot(x, d['k0'], color=COLOR_0, lw=1.2, alpha=0.4,
            linestyle='--', label='Non-Potable (ref)')
    ax.plot(x, d['k1'], color=COLOR_1, lw=1.2, alpha=0.4,
            linestyle='--', label='Potable (ref)')

    # Morphing KDE
    kde_mid = (1 - et) * d['k0'] + et * d['k1']
    ax.fill_between(x, kde_mid, alpha=0.30, color=col)
    ax.plot(x, kde_mid, color=col, lw=2.8,
            label=f'Shift {int(et*100)}%')

    # Sliding mean line
    mean_mid = (1 - et) * d['mean_0'] + et * d['mean_1']
    ax.axvline(d['mean_0'], color=COLOR_0, lw=1.0, linestyle=':', alpha=0.45)
    ax.axvline(d['mean_1'], color=COLOR_1, lw=1.0, linestyle=':', alpha=0.45)
    ax.axvline(mean_mid, color=col, lw=2.0, alpha=0.9,
               label=f'Mean: {mean_mid:.2f}')

    # Shaded shift zone
    ax.axvspan(min(d['mean_0'], mean_mid),
               max(d['mean_0'], mean_mid),
               alpha=0.06, color=COLOR_SHIFT)

    # Std dev bracket
    std_mid  = (1 - et) * d['std_0']  + et * d['std_1']
    kurt_mid = (1 - et) * d['kurt_0'] + et * d['kurt_1']
    peak_y   = kde_mid.max() * 0.55
    ax.annotate('', xy=(mean_mid + std_mid, peak_y),
                xytext=(mean_mid - std_mid, peak_y),
                arrowprops=dict(arrowstyle='<->', color=col,
                                lw=1.4, shrinkA=0, shrinkB=0))
    ax.text(mean_mid, peak_y * 1.06, f'±{std_mid:.2f}',
            ha='center', va='bottom', fontsize=8, color='#555')

    # Stats box
    delta = d['mean_1'] - d['mean_0']
    arrow = '▶' if delta > 0 else '◀'
    info  = (f"Mean shift: {arrow} {abs(delta):.3f}\n"
             f"Std dev:    {std_mid:.3f}\n"
             f"Kurtosis:   {kurt_mid:.3f}")
    ax.text(0.015, 0.97, info, transform=ax.transAxes,
            fontsize=8.5, color='#333', va='top', linespacing=1.6,
            bbox=dict(boxstyle='round,pad=0.5', fc='#f7f7f7',
                      ec='#ddd', lw=0.8))

    # Progress dots
    for i in range(len(features)):
        dot_col = col if i == fi else '#e0e0e0'
        ax.text(0.98 - (len(features)-1-i)*0.026, 0.97, '●',
                transform=ax.transAxes, fontsize=7,
                color=dot_col, ha='center', va='top')

    ax.set_xlim(x[0], x[-1])
    ax.set_ylim(0, d['y_max'])
    ax.set_title(f"Distribution Shift — {d['feature']}:  Non-Potable → Potable",
                 fontsize=13, fontweight='bold', color='#111', pad=10)
    ax.set_xlabel(d['feature'], color='#333', fontsize=10)
    ax.set_ylabel('Density', color='#333', fontsize=10)
    ax.legend(fontsize=8.5, facecolor='white', edgecolor='#ddd',
              labelcolor='#333', loc='upper right', framealpha=0.9)

ani = FuncAnimation(fig, animate, frames=len(frame_list),
                    interval=55, repeat=True)
gif_path = "panel1_distribution_shift.gif"
ani.save(gif_path, writer=PillowWriter(fps=20))
plt.close(fig)
display(Image(gif_path))
print(f"Distribution Shift Animation saved: {gif_path}")


print("\n" + "=" * 60)
print(" OUTLIER DETECTION (CRITICAL FOR WATER QUALITY)")
print("=" * 60)

def detect_outliers_iqr(data, feature):
    """Detect outliers using IQR method"""
    Q1 = data[feature].quantile(0.25)
    Q3 = data[feature].quantile(0.75)
    IQR = Q3 - Q1
    lower_bound = Q1 - 1.5 * IQR
    upper_bound = Q3 + 1.5 * IQR
    outliers = data[(data[feature] < lower_bound) | (data[feature] > upper_bound)]
    return outliers, lower_bound, upper_bound

outlier_summary = {}
fig, axes = plt.subplots(3, 3, figsize=(16, 14))
axes = axes.ravel()

for idx, feature in enumerate(features):
    ax = axes[idx]
    
    # Detect outliers
    outliers, lower, upper = detect_outliers_iqr(df, feature)
    outlier_summary[feature] = len(outliers)
    
    # Plot
    clean_data = df[(df[feature] >= lower) & (df[feature] <= upper)][feature]
    ax.scatter(range(len(clean_data)), clean_data, alpha=0.6, color='#00F7FF', label='Normal')
    ax.scatter(outliers.index, outliers[feature], color='#FF0087', label='Outliers', s=50)
    
    ax.axhline(y=lower, color='yellow', linestyle='--', alpha=0.7, label='IQR Bounds')
    ax.axhline(y=upper, color='yellow', linestyle='--', alpha=0.7)
    
    ax.set_title(f'{feature} - Outliers: {len(outliers)}', fontsize=12, fontweight='bold', color='white')
    ax.set_ylabel(feature, color='white')
    ax.legend()
    ax.grid(True, alpha=0.3)

plt.suptitle('Outlier Detection Using IQR Method (Yellow lines = bounds)', 
             fontsize=16, fontweight='bold', color='black', y=1.02)
plt.tight_layout()
plt.show()

print("\n🚨 Outlier Summary:")
for feature, count in sorted(outlier_summary.items(), key=lambda x: x[1], reverse=True):
    percentage = (count / len(df)) * 100
    print(f"  • {feature}: {count} outliers ({percentage:.1f}%)")



