total     = len(df)
n_potable = (df['Potability'] == 1).sum()
n_nonpot  = (df['Potability'] == 0).sum()
frames    = 60

fig, ax = plt.subplots(figsize=(10, 6))
fig.patch.set_facecolor('white')

def animate(frame):
    ax.cla()
    ax.set_facecolor('white')
    t      = frame / (frames - 1)
    ease   = 1 - (1 - t) ** 3
    val_np = int(n_nonpot  * ease)
    val_p  = int(n_potable * ease)

    bars = ax.bar(['Non-Potable', 'Potable'], [val_np, val_p],
                  color=['#FF0087', '#00F7FF'], width=0.5,   # ← updated
                  edgecolor='white', linewidth=1.2)

    # Percentage labels inside bars
    for bar, val in zip(bars, [val_np, val_p]):
        pct = (val / total) * 100
        if bar.get_height() > 80:
            ax.text(bar.get_x() + bar.get_width() / 2,
                    bar.get_height() - 120,
                    f'{val:,}\n({pct:.1f}%)',
                    ha='center', va='top',
                    fontsize=11, fontweight='bold', color='white')

    # Total samples counter
    ax.text(0.98, 0.97, f'Samples counted: {val_np + val_p:,} / {total:,}',
            transform=ax.transAxes, ha='right', va='top',
            fontsize=9, color='#888')

    # Imbalance ratio box
    if val_p > 0:
        ratio = val_np / val_p
        ax.text(0.02, 0.97, f'Imbalance ratio: {ratio:.2f}:1',
                transform=ax.transAxes, ha='left', va='top',
                fontsize=9, color='#e05c2a',
                bbox=dict(boxstyle='round,pad=0.4', fc='#fff5f0',
                          ec='#e05c2a', lw=0.8))

    ax.set_ylim(0, n_nonpot * 1.25)
    ax.set_title('Figure 1 — Class Imbalance: Potable vs Non-Potable Water Samples',
                 fontsize=12, fontweight='bold', color='#111', pad=12)
    ax.set_ylabel('Number of Samples', color='#333', fontsize=11)
    ax.tick_params(colors='#333')
    ax.grid(True, alpha=0.2, linestyle='--', color='#aaa', axis='y')
    for sp in ax.spines.values():
        sp.set_edgecolor('#ddd')

ani = FuncAnimation(fig, animate, frames=frames, interval=20, repeat=False)
gif_path = "trend1_class_imbalance.gif"
ani.save(gif_path, writer=PillowWriter(fps=24))
plt.close(fig)
