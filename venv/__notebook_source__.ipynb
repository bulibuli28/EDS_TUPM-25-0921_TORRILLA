    'IQR':      df[features].quantile(0.75) - df[features].quantile(0.25),
}).round(3)

print(stats.to_string())

print("\nSkewness Interpretation:")
for feat in features:
    skew = df[feat].skew()
    if skew > 1:
        direction = "strongly right-skewed ➡️"
    elif skew > 0.5:
        direction = "moderately right-skewed ↗️"
    elif skew < -1:
        direction = "strongly left-skewed ⬅️"
    elif skew < -0.5:
        direction = "moderately left-skewed ↙️"
    else:
        direction = "approximately symmetric ↔️"
    print(f"  • {feat:<20} skew={skew:+.3f}  →  {direction}")


